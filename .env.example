FACEIT_API_KEY=
# Principal: groq (default) | gemini. Fallback automático no outro se o principal falhar.
# LLM_PROVIDER=groq
# LLM_FALLBACK=true
GEMINI_API_KEY=
# Use 3.5 Flash Lite (~500 RPD). NÃO use Flash “cheio” (~20 RPD no free).
# GEMINI_MODEL=gemini-3.5-flash-lite
# Groq free: llama-3.1-8b-instant ~14.4k RPD; llama-3.3-70b-versatile ~1k RPD
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# Cache do diagnóstico em ms (default 24h)
# INSIGHT_CACHE_TTL_MS=86400000
